<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.example.recipefinder">

    <!-- 1. CRUCIAL: Tell the system this app needs internet access to load recipes from TheMealDB -->
    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:usesCleartextTraffic="true"
        android:theme="@style/Theme.AppCompat.Light.NoActionBar">

        <!-- 2. SPLASH SCREEN: Main entry point of your app with full-screen configuration -->
        <activity
            android:name=".activities.SplashActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- 3. AUTHENTICATION MODULE: Registered activities for logging in and signing up -->
        <activity
            android:name=".activities.LoginActivity"
            android:exported="false" />

        <activity
            android:name=".activities.SignupActivity"
            android:exported="false" />

        <!-- 4. MAIN CONTAINER: Houses your Bottom Navigation Bar and 4 main fragments -->
        <activity
            android:name=".activities.MainActivity"
            android:exported="false" />

        <!-- 5. DETAILS MODULE: Opens when a user clicks any recipe card from Home or Search -->
        <activity
            android:name=".activities.RecipeDetailActivity"
            android:exported="false" />

    </application>
</manifest>